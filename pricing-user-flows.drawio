        <mxCell id="priority_box" value="ONCELIK (Priority)&#xa;&#xa;Bir musteriye birden fazla liste&#xa;uygulandiginda yuksek oncelikli kazanir.&#xa;&#xa;BASE (priority: 0) &lt; SALE (priority: 10)&#xa;&lt; CUSTOM (priority: 20)&#xa;&#xa;Sistem su siraya bakar:&#xa;1. Musterinin gruplarina bagli listeler&#xa;2. validFrom/validTo tarih araliginda mi?&#xa;3. isActive = true mi?&#xa;4. En yuksek priority kazanir" style="shape=note;whiteSpace=wrap;size=15;fillColor=#c8e6c9;strokeColor=#388E3C;fontSize=11;align=left;spacingLeft=10;verticalAlign=middle;" vertex="1" parent="1">
