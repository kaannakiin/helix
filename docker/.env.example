# ============================================================
# Helix Environment Variables
# ============================================================
# Copy to project root:  cp docker/.env.example .env
# Fill in all CHANGE_ME values before running docker compose.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=helix
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=helix

# ── MinIO (Object Storage) ──────────────────────────────
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME_strong_password
MINIO_BUCKET=helix

# ── JWT Secrets (Admin Auth) ────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# ── JWT Secrets (Customer / Storefront Auth) ─────────────
CUSTOMER_JWT_SECRET=CHANGE_ME
CUSTOMER_JWT_REFRESH_SECRET=CHANGE_ME

# ── Domain & TLS ────────────────────────────────────────
PORTAL_HOSTNAME=admin.yourdomain.com
# Generate with: openssl rand -hex 16
TLS_ASK_SECRET=CHANGE_ME_min_32_chars
CORS_ORIGIN=https://admin.yourdomain.com
FRONTEND_URL=https://admin.yourdomain.com

# ── Google OAuth (optional) ──────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://admin.yourdomain.com/api/auth/google/callback

# ── Facebook OAuth (optional) ────────────────────────────
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=https://admin.yourdomain.com/api/auth/facebook/callback

# ── Instagram OAuth (optional) ───────────────────────────
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=https://admin.yourdomain.com/api/auth/instagram/callback

# ── Admin User (for initial seed only) ──────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME=Admin
ADMIN_SURNAME=User
