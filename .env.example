# ============================================================
# Helix Docker/Portainer Environment Template
# ============================================================
# Portainer and `docker compose` should read this file as the
# project-level `.env`. Copy it to `.env` and fill the secrets.
# ============================================================

# ── Required: PostgreSQL ──────────────────────────────────
POSTGRES_USER=helix
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=helix

# ── Required: MinIO ───────────────────────────────────────
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME_strong_password
MINIO_BUCKET=helix

# ── Required: Admin Auth JWT ──────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# ── Required: Customer Auth JWT ───────────────────────────
# Generate with: openssl rand -base64 32
CUSTOMER_JWT_SECRET=CHANGE_ME
CUSTOMER_JWT_REFRESH_SECRET=CHANGE_ME

# ── Required: Domain / TLS / Router ───────────────────────
PORTAL_HOSTNAME=portal.yourdomain.com
CORS_ORIGIN=https://portal.yourdomain.com
FRONTEND_URL=https://portal.yourdomain.com
# Generate with: openssl rand -hex 16
TLS_ASK_SECRET=CHANGE_ME_min_32_chars
# Generate with: openssl rand -hex 24
ROUTER_INTERNAL_SECRET=CHANGE_ME_internal_router_secret

# ── Optional: OAuth Providers ─────────────────────────────
# Leave blank if the provider is not enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=

# ── Required: Initial Admin Seed ──────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME=Admin
ADMIN_SURNAME=User
