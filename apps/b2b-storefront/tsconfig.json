{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "noEmit": true,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "customConditions": ["@org/source"],
    "resolveJsonModule": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    },
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/**/*.js",
    "app/**/*.jsx",
    "core/**/*.ts",
    "core/**/*.tsx",
    "../../apps/b2b-storefront/.next/types/**/*.ts",
    "../../dist/apps/b2b-storefront/.next/types/**/*.ts",
    "next-env.d.ts"
  ],
  "exclude": [
    "out-tsc",
    "dist",
    "node_modules",
    "jest.config.ts",
    "jest.config.cts",
    "app/**/*.spec.ts",
    "app/**/*.test.ts",
    ".next"
  ],
  "references": [
    {
      "path": "../../packages/prisma"
    },
    {
      "path": "../../packages/utils"
    },
    {
      "path": "../../packages/i18n"
    },
    {
      "path": "../../packages/constants"
    },
    {
      "path": "../../packages/hooks"
    },
    {
      "path": "../../packages/types"
    }
  ]
}
