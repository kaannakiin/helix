{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["node", "multer"],
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "out-tsc",
    "dist",
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],
  "references": [
    {
      "path": "../../packages/utils/tsconfig.lib.json"
    },
    {
      "path": "../../packages/types/tsconfig.lib.json"
    },
    {
      "path": "../../packages/schemas/tsconfig.lib.json"
    },
    {
      "path": "../../packages/prisma/tsconfig.lib.json"
    },
    {
      "path": "../../packages/i18n/tsconfig.lib.json"
    },
    {
      "path": "../../packages/constants/tsconfig.lib.json"
    }
  ]
}
