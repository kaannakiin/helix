// ─── Rule Engine ──────────────────────────────────────────────────────────────

model RuleTree {
  id           String           @id @default(cuid())
  name         String
  description  String?
  targetEntity RuleTargetEntity
  conditions   Json
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  customerGroups CustomerGroup[]

  @@index([targetEntity])
  @@index([isActive])
  @@index([createdAt])
}
