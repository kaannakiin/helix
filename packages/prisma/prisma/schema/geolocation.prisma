model Country {
  id   String @id @default(cuid())
  code String @unique
  iso3 String @unique

  phoneCode      String?
  currency       String?
  currencyCode   String?
  currencySymbol String?
  native         String?
  region         String?
  subregion      String?
  emoji          String?

  countryType CountryType @default(HAS_STATES)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations CountryTranslation[]
  states       State[]
  warehouses   Warehouse[]

  @@index([code])
  @@index([isActive])
  @@index([sortOrder])
}

model CountryTranslation {
  id String @id @default(cuid())

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  locale Locale

  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, locale])
  @@index([countryId])
  @@index([locale])
}

model State {
  id String @id @default(cuid())

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  name      String
  native    String?
  stateCode String?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations StateTranslation[]
  cities       City[]
  warehouses   Warehouse[]

  @@unique([countryId, name])
  @@index([countryId])
  @@index([name])
  @@index([stateCode])
  @@index([isActive])
  @@index([sortOrder])
}

model StateTranslation {
  id String @id @default(cuid())

  stateId String
  state   State  @relation(fields: [stateId], references: [id], onDelete: Cascade)

  locale Locale

  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stateId, locale])
  @@index([stateId])
  @@index([locale])
}

model City {
  id String @id @default(cuid())

  countryId String
  stateId   String
  state     State  @relation(fields: [stateId], references: [id], onDelete: Cascade)

  name     String
  cityCode String?

  latitude  String?
  longitude String?

  sortOrder Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  districts  District[]
  warehouses Warehouse[]

  @@unique([stateId, name])
  @@index([stateId])
  @@index([countryId])
  @@index([name])
  @@index([isActive])
  @@index([sortOrder])
}

model District {
  id String @id @default(cuid())

  cityId    String
  city      City   @relation(fields: [cityId], references: [id], onDelete: Cascade)
  countryId String
  stateId   String

  name String

  latitude  String?
  longitude String?

  sortOrder Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  towns Town[]

  @@unique([cityId, name])
  @@index([cityId])
  @@index([countryId])
  @@index([stateId])
  @@index([name])
  @@index([isActive])
  @@index([sortOrder])
}

model Town {
  id String @id @default(cuid())

  districtId String
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  name String

  sortOrder Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([districtId, name])
  @@index([districtId])
  @@index([name])
  @@index([isActive])
  @@index([sortOrder])
}
