// ─── Evaluation Job ──────────────────────────────────────────────────────────

model EvaluationJob {
  id           String              @id @default(cuid())
  status       EvaluationJobStatus @default(PENDING)
  targetEntity RuleTargetEntity

  entityId   String
  entityType String

  ruleTreeSnapshot Json?

  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?

  recordsEvaluated Int?
  recordsMatched   Int?

  errorLog     String?
  attemptCount Int     @default(0)
  bullJobId    String?

  triggeredBy String?
  triggerType EvaluationTrigger @default(SCHEDULED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([entityId, entityType])
  @@index([targetEntity])
  @@index([createdAt])
}
