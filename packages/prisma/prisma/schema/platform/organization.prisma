// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name    String
  taxId   String?
  email   String?
  phone   String?
  address String?
  logoUrl String?

  isActive Boolean @default(true)

  parentOrgId String?
  parentOrg   Organization?  @relation("OrgHierarchy", fields: [parentOrgId], references: [id], onDelete: SetNull)
  childOrgs   Organization[] @relation("OrgHierarchy")

  customerGroupMemberships CustomerGroupMember[]
  members                  OrganizationMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([parentOrgId])
  @@index([isActive])
  @@map("organizations")
}

// ─── Organization Member ──────────────────────────────────────────────────────

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  role  OrgMemberRole @default(MEMBER)
  title String?

  parentMemberId String?
  parentMember   OrganizationMember?  @relation("MemberTree", fields: [parentMemberId], references: [id], onDelete: SetNull)
  subordinates   OrganizationMember[] @relation("MemberTree")

  joinedAt DateTime @default(now())
  isActive Boolean  @default(true)

  ancestorClosures   OrgMemberClosure[] @relation("ClosureDescendant")
  descendantClosures OrgMemberClosure[] @relation("ClosureAncestor")

  @@unique([organizationId, customerId])
  @@index([organizationId])
  @@index([customerId])
  @@index([parentMemberId])
  @@index([role])
  @@map("organization_members")
}

// ─── Organization Member Closure (Tree) ─────────────────────────────────────

model OrgMemberClosure {
  id String @id @default(cuid())

  ancestorId String
  ancestor   OrganizationMember @relation("ClosureAncestor", fields: [ancestorId], references: [id], onDelete: Cascade)

  descendantId String
  descendant   OrganizationMember @relation("ClosureDescendant", fields: [descendantId], references: [id], onDelete: Cascade)

  depth Int // 0 = kendisi, 1 = direkt child, 2 = torun...

  @@unique([ancestorId, descendantId])
  @@index([ancestorId, depth])
  @@index([descendantId])
  @@map("org_member_closures")
}
