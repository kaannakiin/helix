model GoogleTaxonomy {
    id       Int  @id
    parentId Int?

    parent   GoogleTaxonomy?  @relation("TaxonomyTree", fields: [parentId], references: [id], onDelete: SetNull)
    children GoogleTaxonomy[] @relation("TaxonomyTree")

    translations GoogleTaxonomyTranslation[]
    products     Product[]

    @@index([parentId])
}

model GoogleTaxonomyTranslation {
    id String @id @default(cuid())

    googleTaxonomyId Int
    googleTaxonomy   GoogleTaxonomy @relation(fields: [googleTaxonomyId], references: [id], onDelete: Cascade)

    locale Locale

    name String
    path String

    @@unique([googleTaxonomyId, locale])
    @@index([googleTaxonomyId])
    @@index([locale])
}
