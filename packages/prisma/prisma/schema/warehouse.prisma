// ─── Warehouse (SAP: Plant/Werk, Netsis: Depo) ─────────────────────────────

model Warehouse {
  id   String @id @default(cuid())
  code String @unique // SAP Plant code / Netsis Depo Kodu
  slug String @unique

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  status WarehouseStatus @default(ACTIVE)

  // Geolocation references (dropdown selection, not free text)
  countryId String
  country   Country @relation(fields: [countryId], references: [id])

  stateId String
  state   State @relation(fields: [stateId], references: [id])

  cityId String?
  city   City? @relation(fields: [cityId], references: [id])

  // Detailed address
  address    String? // Street / building details
  postalCode String?
  lat        Float? // Warehouse exact coordinates
  lng        Float?

  // Contact
  contactName  String?
  contactPhone String?
  contactEmail String?

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations       WarehouseTranslation[]
  zones              WarehouseZone[]
  bins               WarehouseBin[]
  stockLevels        StockLevel[]
  movementGroupsFrom StockMovementGroup[] @relation("MovementGroupSourceWarehouse")
  movementGroupsTo   StockMovementGroup[] @relation("MovementGroupDestWarehouse")

  @@index([storeId])
  @@index([code])
  @@index([slug])
  @@index([status])
  @@index([countryId])
  @@index([stateId])
  @@index([cityId])
  @@index([sortOrder])
}

// ─── Warehouse Translation ──────────────────────────────────────────────────

model WarehouseTranslation {
  id String @id @default(cuid())

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  locale Locale

  name        String // "Main Warehouse" / "Ana Depo"
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([warehouseId, locale])
  @@index([warehouseId])
  @@index([locale])
}

// ─── Warehouse Zone (SAP: Storage Location/Lagerort, Netsis: Depo Bolumu) ───

model WarehouseZone {
  id String @id @default(cuid())

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  code String // Zone code: "A", "ZONE-01"

  // Self-referential hierarchy for deeper nesting
  parentZoneId String?
  parentZone   WarehouseZone?  @relation("ZoneHierarchy", fields: [parentZoneId], references: [id], onDelete: SetNull)
  childZones   WarehouseZone[] @relation("ZoneHierarchy")

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations WarehouseZoneTranslation[]
  bins         WarehouseBin[]
  stockLevels  StockLevel[]

  @@unique([warehouseId, code])
  @@index([warehouseId])
  @@index([parentZoneId])
  @@index([isActive])
  @@index([sortOrder])
}

// ─── Warehouse Zone Translation ─────────────────────────────────────────────

model WarehouseZoneTranslation {
  id String @id @default(cuid())

  warehouseZoneId String
  warehouseZone   WarehouseZone @relation(fields: [warehouseZoneId], references: [id], onDelete: Cascade)

  locale Locale

  name        String // "Zone A - Electronics" / "Zon A - Elektronik"
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([warehouseZoneId, locale])
  @@index([warehouseZoneId])
  @@index([locale])
}

// ─── Warehouse Bin (SAP: Storage Bin/Lagerplatz, Netsis: Raf Konumu) ────────

model WarehouseBin {
  id String @id @default(cuid())

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  zoneId String?
  zone   WarehouseZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  code    String  // Bin code: "A-01-03"
  binType BinType @default(STORAGE)

  // Physical capacity
  maxWeight Float? // kg
  maxVolume Float? // cubic meters
  maxItems  Int?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockLevels StockLevel[]

  @@unique([warehouseId, code])
  @@index([warehouseId])
  @@index([zoneId])
  @@index([binType])
  @@index([isActive])
}
