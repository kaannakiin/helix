{
  "name": "@org/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@org/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./dropzone": {
      "@org/source": "./src/dropzone/index.ts",
      "types": "./dist/dropzone/index.d.ts",
      "import": "./src/dropzone/index.ts",
      "default": "./src/dropzone/index.ts"
    },
    "./inputs/phone-input": {
      "@org/source": "./src/inputs/phone-input/index.ts",
      "types": "./dist/inputs/phone-input/index.d.ts",
      "import": "./src/inputs/phone-input/index.ts",
      "default": "./src/inputs/phone-input/index.ts"
    },
    "./inputs/product-seo-card": {
      "@org/source": "./src/inputs/product-seo-card/index.ts",
      "types": "./dist/inputs/product-seo-card/index.d.ts",
      "import": "./src/inputs/product-seo-card/index.ts",
      "default": "./src/inputs/product-seo-card/index.ts"
    },
    "./inputs/relation-input": {
      "@org/source": "./src/inputs/relation-input/index.ts",
      "types": "./dist/inputs/relation-input/index.d.ts",
      "import": "./src/inputs/relation-input/index.ts",
      "default": "./src/inputs/relation-input/index.ts"
    },
    "./inputs/relation-modal": {
      "@org/source": "./src/inputs/relation-modal/index.ts",
      "types": "./dist/inputs/relation-modal/index.d.ts",
      "import": "./src/inputs/relation-modal/index.ts",
      "default": "./src/inputs/relation-modal/index.ts"
    },
    "./inputs/rich-text-editor": {
      "@org/source": "./src/inputs/rich-text-editor/index.ts",
      "types": "./dist/inputs/rich-text-editor/index.d.ts",
      "import": "./src/inputs/rich-text-editor/index.ts",
      "default": "./src/inputs/rich-text-editor/index.ts"
    },
    "./inputs/*": {
      "@org/source": "./src/inputs/*.tsx",
      "types": "./dist/inputs/*.d.ts",
      "import": "./src/inputs/*.tsx",
      "default": "./src/inputs/*.tsx"
    },
    "./styles.css": "./src/styles.css",
    "./common/*": {
      "@org/source": "./src/common/*.tsx",
      "types": "./dist/common/*.d.ts",
      "import": "./src/common/*.tsx",
      "default": "./src/common/*.tsx"
    },
    "./data-table/*": {
      "@org/source": "./src/data-table/*.tsx",
      "types": "./dist/data-table/*.d.ts",
      "import": "./src/data-table/*.tsx",
      "default": "./src/data-table/*.tsx"
    }
  },
  "nx": {
    "name": "ui"
  },
  "dependencies": {
    "@org/schemas": "*",
    "@org/types": "*",
    "@org/utils": "*",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "clsx": "^2.1.1",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@mantine/core": "^8.0.0",
    "@mantine/dates": "^8.0.0",
    "@mantine/dropzone": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@mantine/notifications": "^8.0.0",
    "ag-grid-community": "^35.1.0",
    "ag-grid-react": "^35.1.0",
    "immer": "^11.1.4",
    "lucide-react": "^0.475.0",
    "next-intl": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "zustand": "^5.0.11"
  }
}
